#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"

# Find dx-metasearch binary
META_SEARCH=""
if command -v dx-metasearch &>/dev/null; then
  META_SEARCH="dx-metasearch"
elif [ -f "$HOME/.local/share/dx/bin/dx-metasearch" ]; then
  META_SEARCH="$HOME/.local/share/dx/bin/dx-metasearch"
elif [ -f "/usr/local/lib/dx/bin/dx-metasearch" ]; then
  META_SEARCH="/usr/local/lib/dx/bin/dx-metasearch"
else
  echo "dx-metasearch not found in PATH or common locations." >&2
  echo "Install it or add its directory to PATH." >&2
  exit 1
fi

cleanup() {
  if [ -n "${META_PID:-}" ]; then
    kill "$META_PID" 2>/dev/null || true
    wait "$META_PID" 2>/dev/null || true
  fi
}
trap cleanup EXIT INT TERM

echo "Starting dx-metasearch..."
"$META_SEARCH" serve &
META_PID=$!

# Wait for metasearch to be ready
for i in $(seq 1 30); do
  if curl -sf "http://127.0.0.1:8888/api/search?q=ping" >/dev/null 2>&1; then
    echo "dx-metasearch is ready"
    break
  fi
  if [ $i -eq 30 ]; then
    echo "dx-metasearch failed to start" >&2
    exit 1
  fi
  sleep 0.5
done

echo "Starting dx dev..."
cd "$ROOT"
exec dx dev "$@"
